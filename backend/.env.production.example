# ── Copy this to .env and fill in your values ──
APP_NAME=WhatsApp Automate
APP_ENV=production
APP_DEBUG=false
APP_PORT=7001
BRIDGE_URL=http://localhost:7002

# Your Raspberry Pi local IP (auto-set by setup.sh)
FRONTEND_URL=http://192.168.1.100
CORS_ORIGINS=*

# MySQL — must be running on the Pi
DB_HOST=localhost
DB_PORT=3306
DB_NAME=whatsapp_automate
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_POOL_SIZE=5

# CHANGE THIS to a random 32+ character string!
JWT_SECRET=change_me_to_a_long_random_secret_key_minimum_32_chars
# Device-bound auth — no password, so the token IS the account (see /auth/device)
JWT_EXPIRE_MINUTES=525600

# WhatsApp Meta Cloud API (only needed if using meta mode)
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_SESSION_DIR=./whatsapp_session
WHATSAPP_WEBHOOK_URL=

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
